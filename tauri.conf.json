{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "CharShift",
  "version": "0.1.0",
  "identifier": "com.codeconvertor.desktop",
  "build": {
    "frontendDist": "./public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CharShift",
        "width": 960,
        "height": 640,
        "resizable": true,
        "center": true,
        "decorations": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "default",
          "windows": ["*"],
          "permissions": ["core:default"]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "nsis": {
        "installMode": "perMachine",
        "languages": ["SimpChinese", "English"]
      }
    }
  }
}
